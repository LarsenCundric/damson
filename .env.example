# damson — your proactive personal agent
# Copy to .env and fill in. The init wizard will prompt you for these too.

# === REQUIRED ===

# Anthropic API key — for damson's reasoning loop
ANTHROPIC_API_KEY=

# Telegram bot token — get one from @BotFather (https://t.me/BotFather)
BOT_TOKEN=

# === OPTIONAL ===

# Where damson keeps its brain (your personal context, conversations, watchers).
# Default: ./brain (in the repo). For production set to e.g. ~/.config/damson/brain
BRAIN_DIR=./brain

# Where damson clones repos for code tasks.
# Default: ~/repos
REPOS_DIR=

# Default Claude Code model for spawned workers. opus | sonnet | haiku
# Default: opus
DEFAULT_CC_MODEL=opus

# Quiet hours (local time). damson keeps working but only delivers a digest
# instead of pinging you. Format: "HH-HH" 24h. Default: 0-8
QUIET_HOURS=0-8

# Heartbeat interval in minutes. Lower = more responsive, more LLM cost.
# Default: 15
HEARTBEAT_INTERVAL_MIN=15

# === SECRETS PASTED VIA /secret AT RUNTIME ===
# Anything else you'd want damson to use (GitHub token, etc.) you can paste
# in Telegram via the /secret command and damson will write it here.
